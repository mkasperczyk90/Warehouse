root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{csproj,props,targets,json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.cs]
# Naming and style — keep close to .NET defaults, file-scoped namespaces, var preference
csharp_style_namespace_declarations = file_scoped:warning
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion
csharp_prefer_braces = true:warning
dotnet_sort_system_directives_first = true

# Async APIs must be awaited
dotnet_diagnostic.CS4014.severity = error

# CA1848: prefer LoggerMessage delegates — we follow this for hot paths,
# enforced as suggestion (source-generated [LoggerMessage] used in modules)
dotnet_diagnostic.CA1848.severity = suggestion

# EF Core migrations are scaffolded by the tooling — don't hold generated code to our analyzer bar.
[**/Migrations/*.cs]
generated_code = true
dotnet_diagnostic.CA1861.severity = none
