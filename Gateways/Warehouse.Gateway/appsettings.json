{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/Warehouse.Identity",
    "ValidIssuer": "http://localhost:8080/realms/Warehouse.Identity",
    "MetadataAddress": "http://localhost:8080/realms/Warehouse.Identity/.well-known/openid-configuration",
    "ClientId": "Warehouse.Gateway",
    "ClientSecret": "aebdf55f036113aad0d040b9cabc2fb1",
    "RequireHttpsMetadata": false
  },
  "ReverseProxy": {
    "Routes": {
      "product-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/products/{**catch-all}" },
        "Metadata": { "RequiredAuthorizationPolicy": "Default" }
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "Match": { "Path": "/api/inventory/{**catch-all}" }
      }
    },
    "Clusters": {
      "product-cluster": {
        "Destinations": {
          "destination1": { "Address": "https://localhost:7248" }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "destination1": { "Address": "https://localhost:7031" }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
