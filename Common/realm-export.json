{
  "id": "Warehouse.Identity",
  "realm": "Warehouse.Identity",
  "enabled": true,
  "roles": {
    "realm": [
      {
        "name": "read",
        "description": "Role for read"
      },
      {
        "name": "write",
        "description": "Role for write"
      }
    ]
  },
  "users": [
    {
      "username": "bob.reader",
      "email": "bob.reader@warehouse.local",
      "emailVerified": true,
      "enabled": true,
      "firstName": "bob",
      "lastName": "reader",
      "credentials": [
        {
          "type": "password",
          "value": "test1234",
          "temporary": false
        }
      ],
      "realmRoles": [
        "read"
      ]
    },
    {
      "username": "johny.writer",
      "email": "johny.writer@warehouse.local",
      "emailVerified": true,
      "enabled": true,
      "firstName": "johny",
      "lastName": "writer",
      "credentials": [
        {
          "type": "password",
          "value": "test1234",
          "temporary": false
        }
      ],
      "realmRoles": [
        "read",
        "write"
      ]
    }
  ],
  "clients": [
    {
      "clientId": "ProductService",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "InventoryService",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    },{
      "clientId": "test-client",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "aud-inventory",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "InventoryService",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "aud-product",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "ProductService",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ]
}